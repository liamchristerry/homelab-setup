---
# Copy this to secrets.yml and fill in your values
# Then encrypt with: ansible-vault encrypt secrets.yml

# Proxmox credentials
proxmox_password: "YourProxmoxRootPassword"

# Temporary root password for new LXC containers
lxc_root_password: "TempRootPassword123"

# Pi-hole web interface password
pihole_web_password: "YourPiholePassword"

# Cloudflare Tunnel (optional - only if using Cloudflare Tunnel)
cloudflare_tunnel_id: "your-tunnel-id-here"
cloudflare_tunnel_credentials:
  AccountTag: "your-account-tag"
  TunnelSecret: "your-tunnel-secret"
  TunnelID: "your-tunnel-id"

# Domain name (if you have one)
domain: "yourdomain.com"
