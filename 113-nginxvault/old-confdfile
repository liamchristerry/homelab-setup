##########################################################
# Proxmox Service
##########################################################

# Upstream block for load balancing proxmox
upstream proxmox_backend {
    server 192.168.99.211:8006;
    server 192.168.99.212:8006;
    server 192.168.99.213:8006;
}

server {
    listen 192.168.99.100:443 ssl;
    server_name proxmox.home.lab;

    location / {
        proxy_pass https://proxmox_backend;
        proxy_ssl_verify off;
    }
}