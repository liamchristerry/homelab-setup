# =====================================================
# Reverse Proxy Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# Last updated: {{ ansible_date_time.iso8601 }}
# =====================================================

# WebSocket support map (conditional)
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Common proxy headers
proxy_set_header Host $host;
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;
proxy_read_timeout 90;

# WebSocket headers (conditionally applied)
proxy_set_header Upgrade $http_upgrade;
proxy_set_header Connection $connection_upgrade;

# Preserve cookies for authentication
proxy_pass_header Set-Cookie;
proxy_pass_header Authorization;
proxy_pass_request_headers on;

# Buffer settings
proxy_buffering off;
proxy_request_buffering off;
proxy_http_version 1.1;

# SSL certificates (global)
ssl_certificate {{ nginx_ssl_cert }};
ssl_certificate_key {{ nginx_ssl_key }};

access_log /var/log/nginx/access.log;
error_log /var/log/nginx/error.log;

##########################################################
# Global HTTP to HTTPS Redirect
##########################################################

server {
    listen {{ nginx_listen_ip }}:80 default_server;
    server_name _;
    return 301 https://$host$request_uri;
}

{% for service in reverse_proxy_services %}
##########################################################
# {{ service.name | title }} Service
##########################################################

{% if service.enable_load_balancing | default(false) %}
# Upstream block for load balancing {{ service.name }}
upstream {{ service.name }}_backend {
{% for backend in service.backend_servers %}
    server {{ backend.host }}:{{ backend.port }};
{% endfor %}
}

{% endif %}
server {
    listen {{ nginx_listen_ip }}:443 ssl;
    server_name {{ service.server_name }};

    location / {
{% if service.enable_load_balancing | default(false) %}
        proxy_pass {{ service.backend_protocol }}://{{ service.name }}_backend;
{% else %}
        proxy_pass {{ service.backend_protocol }}://{{ service.backend_host }}:{{ service.backend_port }}/;
{% endif %}
        proxy_ssl_verify off;
{% if service.custom_timeouts is defined %}
        
        # Custom timeouts for {{ service.name }}
{% if service.custom_timeouts.read is defined %}
        proxy_read_timeout {{ service.custom_timeouts.read }};
{% endif %}
{% if service.custom_timeouts.send is defined %}
        proxy_send_timeout {{ service.custom_timeouts.send }};
{% endif %}
{% endif %}
    }
}

{% endfor %}
