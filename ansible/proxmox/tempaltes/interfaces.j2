# /etc/network/interfaces
# Managed by Ansible - Do not edit manually

auto lo
iface lo inet loopback

iface {{ primary_interface }} inet manual

auto {{ bridge_interface }}
iface {{ bridge_interface }} inet static
    address {{ ansible_default_ipv4.address }}/{{ ansible_default_ipv4.netmask | ansible.utils.ipaddr('prefix') }}
    gateway {{ ansible_default_ipv4.gateway }}
    bridge-ports {{ primary_interface }}
    bridge-stp off
    bridge-fd 0
    bridge-vlan-aware yes
    bridge-vids {{ bridge_vlans }}

